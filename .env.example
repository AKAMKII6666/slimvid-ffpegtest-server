# Dev Probe Compute Worker — 复制为 .env，勿提交
# npm run dev / npm start 通过 node --env-file=.env 自动加载（Node >= 20.6）

# 必填：与主 app SLIMVID_DEV_PROBE_WORKER_TOKEN 相同
PROBE_WORKER_AUTH_TOKEN=

# 推荐
# PROBE_WORKER_CONFIG=./config/probe-worker.local.json

# --- R2（VMAF sub-75 截图，风格对齐主 app SLIMVID_R2_*）---
# PROBE_WORKER_R2_ACCOUNT_ID=your_cloudflare_account_id
# PROBE_WORKER_R2_BUCKET=your_r2_bucket_name
# PROBE_WORKER_R2_ACCESS_KEY_ID=your_r2_access_key_id
# PROBE_WORKER_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# PROBE_WORKER_R2_OBJECT_KEY_PREFIX=replacement-uploads/company
# PROBE_WORKER_R2_PUBLIC_BASE_URL=https://your-r2-public-base-url

# 可选 override（见 docs/AI与人类/configuration.md）
# PROBE_WORKER_PORT=3099
# PROBE_WORKER_MAX_VMAF_CONCURRENCY=2
# PROBE_WORKER_VMAF_USE_GPU=1
# PROBE_WORKER_SCREENSHOTS_ENABLED=1
